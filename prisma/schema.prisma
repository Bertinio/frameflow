generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id             String  @id @default(cuid())
  email          String  @unique
  passwordHash   String
  role           String
  createdAt      DateTime @default(now())

  installerOrders Order[]
  quotes          Quote[]
}

model Order {
  id          String      @id @default(cuid())
  installerId String
  installer   User        @relation(fields: [installerId], references: [id])
  status      String      @default("RECEIVED")
  totalPrice  Decimal     @default(0)
  createdAt   DateTime    @default(now())
  items       OrderItem[]
}

model Quote {
  id          String      @id @default(cuid())
  installerId String
  installer   User        @relation(fields: [installerId], references: [id])
  totalPrice  Decimal     @default(0)
  status      String      @default("DRAFT")
  createdAt   DateTime    @default(now())
  items       QuoteItem[]
}

model QuoteItem {
  id         String   @id @default(cuid())
  quoteId    String
  quote      Quote    @relation(fields: [quoteId], references: [id])
  type       String
  width      Int
  height     Int
  color      String
  glass      String
  options    String
  unitPrice  Decimal
  totalPrice Decimal
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  type        String
  width       Int
  height      Int
  color       String
  glass       String
  options     String
  quantity    Int      @default(1)
  profileType String?
  unitPrice   Decimal
  totalPrice  Decimal
}


